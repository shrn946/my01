generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  categoryId  String?
  description String
  overview    String
  problem     String
  solution    String
  result      String
  tools       String[]
  image       String
  gallery     String[]
  liveUrl     String?
  featured    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  category    Category? @relation(fields: [categoryId], references: [id])
  tags        Tag[]     @relation("ProjectTags")
}

model BlogPost {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  excerpt         String
  content         String
  author          String
  image           String
  publishedAt     DateTime  @default(now())
  categoryId      String?
  featured        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  metaDescription String?
  metaTitle       String?
  category        Category? @relation(fields: [categoryId], references: [id])
  tags            Tag[]     @relation("BlogTags")
}

model Review {
  id        String   @id @default(cuid())
  client    String
  company   String
  country   String
  rating    Int      @default(5)
  text      String
  platform  String
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  active    Boolean  @default(true)
  image     String?
  service   String?
  sortOrder Int      @default(0)
}

model HeroSlide {
  id         String   @id @default(cuid())
  title      String
  subtitle   String
  buttonText String
  buttonLink String
  image      String
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model InnerHeroSettings {
  id                   String   @id @default(cuid())
  fallbackImage        String
  overlayColor         String   @default("#07111f")
  overlayOpacity       Int      @default(65)
  titleColor           String   @default("#ffffff")
  breadcrumbColor      String   @default("#dbeafe")
  heroHeight           Int      @default(360)
  backgroundPosition   String   @default("center center")
  backgroundAttachment String   @default("scroll")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ContactMessage {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  projectType String
  budget      String
  message     String
  createdAt   DateTime @default(now())
}

model MediaAsset {
  id        String   @id @default(cuid())
  fileName  String
  url       String
  mimeType  String
  size      Int
  alt       String?
  createdAt DateTime @default(now())
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  createdAt DateTime   @default(now())
  blogPosts BlogPost[]
  projects  Project[]
}

model Tag {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  createdAt DateTime   @default(now())
  blogPosts BlogPost[] @relation("BlogTags")
  projects  Project[]  @relation("ProjectTags")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id                     String     @id @default(cuid())
  businessName           String?
  website                String
  email                  String?
  phone                  String?
  address                String?
  city                   String?
  category               String?
  source                 String?
  status                 String     @default("New")
  leadScore              Int?
  websiteScore           Int?
  performanceScore       Int?
  seoScore               Int?
  accessibilityScore     Int?
  bestPracticesScore     Int?
  mobileScore            Int?
  desktopScore           Int?
  topIssues              String?
  notes                  String?
  followUpDate           DateTime?
  lastContactedAt        DateTime?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  beforeAfterImage       String?
  conversionScore        Int?
  designScore            Int?
  desktopImage           String?
  improvementProposals   String[]
  mobileImage            String?
  pageSpeedAccessibility Int?
  pageSpeedBestPractices Int?
  pageSpeedPerformance   Int?
  pageSpeedSeo           Int?
  proposalImage          String?
  reportStatus           String     @default("Not Generated")
  proposalImageTech      String?
  designAnalysis         Json?
  developerComments      String?
  emailLogs              EmailLog[]
}

model PortfolioExample {
  id          String   @id @default(cuid())
  category    String
  title       String
  url         String
  thumbnail   String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailTemplate {
  id        String     @id @default(cuid())
  name      String
  subject   String
  body      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  emailLogs EmailLog[]
}

model EmailLog {
  id           String         @id @default(cuid())
  leadId       String
  templateId   String?
  toEmail      String
  subject      String
  body         String
  status       String
  errorMessage String?
  sentAt       DateTime       @default(now())
  lead         Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  template     EmailTemplate? @relation(fields: [templateId], references: [id])
}

model Settings {
  id              String   @id @default("default")
  senderName      String?
  senderEmail     String?
  resendApiKey    String?
  companyName     String?
  portfolioUrl    String?
  demoWebsiteUrls String?
  updatedAt       DateTime @updatedAt
}

enum Role {
  ADMIN
  CLIENT
}
