generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  categoryId  String?
  description String
  overview    String
  problem     String
  solution    String
  result      String
  tools       String[]
  image       String
  gallery     String[]
  liveUrl     String?
  featured    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  category    Category? @relation(fields: [categoryId], references: [id])
  tags        Tag[]     @relation("ProjectTags")
}

model BlogPost {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  excerpt         String
  content         String
  author          String
  image           String
  publishedAt     DateTime  @default(now())
  categoryId      String?
  featured        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  metaDescription String?
  metaTitle       String?
  category        Category? @relation(fields: [categoryId], references: [id])
  tags            Tag[]     @relation("BlogTags")
}

model Review {
  id        String   @id @default(cuid())
  client    String
  company   String
  country   String
  rating    Int      @default(5)
  text      String
  platform  String
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  active    Boolean  @default(true)
  image     String?
  service   String?
  sortOrder Int      @default(0)
}

model HeroSlide {
  id         String   @id @default(cuid())
  title      String
  subtitle   String
  buttonText String
  buttonLink String
  image      String
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model InnerHeroSettings {
  id                   String   @id @default(cuid())
  fallbackImage        String
  overlayColor         String   @default("#07111f")
  overlayOpacity       Int      @default(65)
  titleColor           String   @default("#ffffff")
  breadcrumbColor      String   @default("#dbeafe")
  heroHeight           Int      @default(360)
  backgroundPosition   String   @default("center center")
  backgroundAttachment String   @default("scroll")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ContactMessage {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  projectType String
  budget      String
  message     String
  createdAt   DateTime @default(now())
}

model MediaAsset {
  id        String   @id @default(cuid())
  fileName  String
  url       String
  mimeType  String
  size      Int
  alt       String?
  createdAt DateTime @default(now())
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  createdAt DateTime   @default(now())
  blogPosts BlogPost[]
  projects  Project[]
}

model Tag {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  createdAt DateTime   @default(now())
  blogPosts BlogPost[] @relation("BlogTags")
  projects  Project[]  @relation("ProjectTags")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id                     String     @id @default(cuid())
  businessName           String?
  website                String
  email                  String?
  phone                  String?
  address                String?
  city                   String?
  instagram              String?
  facebook               String?
  linkedin               String?
  twitter                String?
  category               String?
  source                 String?
  status                 String     @default("New")
  leadScore              Int?
  websiteScore           Int?
  performanceScore       Int?
  seoScore               Int?
  accessibilityScore     Int?
  bestPracticesScore     Int?
  mobileScore            Int?
  desktopScore           Int?
  topIssues              String?
  notes                  String?
  followUpDate           DateTime?
  followUpStatus         String?    @default("None")
  lastContactedAt        DateTime?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  beforeAfterImage       String?
  conversionScore        Int?
  designScore            Int?
  desktopImage           String?
  improvementProposals   String[]
  mobileImage            String?
  pageSpeedAccessibility Int?
  pageSpeedBestPractices Int?
  pageSpeedPerformance   Int?
  pageSpeedSeo           Int?
  proposalImage          String?
  reportStatus           String     @default("Not Generated")
  proposalImageTech      String?
  designAnalysis         Json?
  developerComments      String?
  aiAnalysis             Json?
  reportContent          Json?
  reportMedia            Json?
  reportPdf              String?
  reportImage            String?
  proposalPdf            String?
  emailLogs              EmailLog[]

  @@index([category])
}

model PortfolioExample {
  id          String   @id @default(cuid())
  category    String
  title       String
  url         String
  thumbnail   String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailTemplate {
  id        String     @id @default(cuid())
  name      String
  subject   String
  body      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  emailLogs EmailLog[]
}

model EmailLog {
  id           String         @id @default(cuid())
  leadId       String
  templateId   String?
  toEmail      String
  subject      String
  body         String
  status       String
  errorMessage String?
  sentAt       DateTime       @default(now())
  lead         Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  template     EmailTemplate? @relation(fields: [templateId], references: [id])
}

model Settings {
  id              String   @id @default("default")
  senderName      String?
  senderEmail     String?
  resendApiKey    String?
  companyName     String?
  portfolioUrl    String?
  demoWebsiteUrls String?
  geminiModel     String?  @default("gemini-3.1-flash-lite")
  navItems        Json?
  updatedAt       DateTime @updatedAt

  googleSearchEnabled Boolean @default(true)
  googleApiKey        String?
  googleSearchCx      String?
  googleSearchLimit   Int     @default(40)

  followUpEnabled     Boolean @default(true)
  followUpSubject     String? @default("Checking in regarding your website")
  followUpBody        String? @default("Hi,\n\nI just wanted to follow up on the website audit I sent over recently. Have you had a chance to look at it?\n\nLet me know if you have any questions or if you'd like to schedule a quick call to go over the recommendations.\n\nBest regards,")

  serpApiSearchEnabled Boolean @default(true)
  serpApiKey           String?
  serpApiSearchLimit   Int     @default(40)

  searchProviderMode   String  @default("Auto")

  // Target Locations (by country)
  locationsUsa          String[] @default(["Houston", "Dallas", "Phoenix", "Atlanta", "Charlotte", "Tampa", "Denver", "Austin", "San Antonio", "Orlando", "Miami", "Jacksonville", "Raleigh", "Nashville", "Las Vegas", "Salt Lake City", "Columbus", "Indianapolis", "Kansas City"])
  locationsUk           String[] @default(["London", "Manchester", "Birmingham", "Leeds", "Liverpool", "Bristol", "Nottingham", "Sheffield", "Leicester", "Newcastle"])
  locationsCanada       String[] @default(["Toronto", "Calgary", "Vancouver", "Ottawa", "Edmonton", "Winnipeg", "Mississauga", "Hamilton"])
  locationsGermany      String[] @default(["Berlin", "Hamburg", "Munich", "Frankfurt", "Cologne", "Stuttgart", "Düsseldorf"])
  locationsAustralia    String[] @default(["Sydney", "Melbourne", "Brisbane", "Perth", "Adelaide"])
  locationsNewZealand   String[] @default(["Auckland", "Wellington", "Christchurch"])
  locationsPriority     String[] @default(["Houston", "Dallas", "Phoenix", "Atlanta", "Manchester", "Toronto", "London", "Austin", "Miami", "Calgary"])

  // Cold Outreach Categories
  categories            String[] @default(["Dentists", "Lawyers", "Accountants", "Real Estate Agents", "Roofing Companies", "HVAC Companies", "Plumbers", "Electricians", "Home Remodelers", "Landscaping Companies", "Pest Control Companies", "Cleaning Services", "Moving Companies", "Chiropractors", "Physical Therapists", "Medical Clinics", "Veterinarians", "Dental Clinics", "Restaurants", "Coffee Shops", "Auto Repair Shops", "Car Dealerships", "Insurance Agencies", "Mortgage Brokers", "Financial Advisors", "Marketing Agencies", "Web Design Agencies", "IT Support Companies", "Managed Service Providers (MSPs)", "Construction Companies", "Solar Installers", "Property Management Companies", "Private Schools", "Tutoring Centers", "Gyms & Fitness Centers", "Beauty Salons", "Spas", "Wedding Photographers", "Law Firms", "Accounting Firms"])
}

model SearchUsage {
  id          String   @id @default(cuid())
  date        String   @unique
  googleCount Int      @default(0)
  serpCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  ADMIN
  CLIENT
}


